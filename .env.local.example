# --- Storefront ---------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token

# --- Shopify Admin (launch metaobject upserts, customer fallbacks) ------------
SHOPIFY_ADMIN_TOKEN=your_shopify_admin_api_token
SHOPIFY_LAUNCH_METAOBJECT_TYPE=launch
SHOPIFY_LAUNCH_LOOKBOOK_IMAGE_IDS=

# --- Newsletter (Klaviyo) -----------------------------------------------------
KLAVIYO_PRIVATE_API_KEY=
KLAVIYO_NEWSLETTER_LIST_ID=
KLAVIYO_API_REVISION=2025-07-15

# --- Contact form (Resend) ----------------------------------------------------
RESEND_API_KEY=
CONTACT_FORM_FROM_EMAIL=POSTED <contact@yourdomain.com>
CONTACT_FORM_TO_EMAIL=info@postedhi.com

# --- Local-only design / product-draft scripts --------------------------------
REPLICATE_API_TOKEN=
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=

# --- Quine bus (Phase 1 pilot wiring) -----------------------------------------
# Bus is a Supabase project at https://ypaewzkipaxczdjmpwts.supabase.co
# Use the service-role key in Phase 1 (Phase 1 auth model — see bus-spec.md).
# Both vars are required for the daily heartbeat cron and content-publish
# emits to land on the bus. Populate per-environment in Vercel project env
# vars; never commit real values.
QUINE_BUS_URL=https://ypaewzkipaxczdjmpwts.supabase.co
QUINE_BUS_KEY=

# Vercel Cron auth (set automatically in Vercel; only needed locally if
# testing the cron endpoint with a bearer token).
CRON_SECRET=
